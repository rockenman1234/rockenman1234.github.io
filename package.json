{
  "name": "rockenman1234.github.io",
  "version": "1.0.0",
  "description": "Alex Jenkins - Personal Portfolio (System 6 Edition)",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "check:duplicates": "jscpd --format javascript --min-lines 8 --min-tokens 60 --reporters console src public",
    "check:deadcode": "knip --include files,dependencies"
  },
  "keywords": [],
  "author": "Alex Jenkins",
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "jscpd": "^4.0.8",
    "knip": "^6.1.0",
    "vite": "^8.0.3"
  },
  "knip": {
    "entry": [
      "index.html",
      "public/sw.js",
      "public/utils.js"
    ],
    "project": [
      "src/**/*.js",
      "public/**/*.js"
    ],
    "ignoreDependencies": [
      "@sakun/system.css"
    ]
  },
  "dependencies": {
    "@sakun/system.css": "^0.1.11"
  }
}
